[Unit]
Description=Inky Are.na Display
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/home/jcampbell/inky-arena
ExecStart=/home/jcampbell/inky-app/.venv/bin/python /home/jcampbell/inky-arena/main.py
Restart=always
RestartSec=10
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
